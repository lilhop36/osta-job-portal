# Allow Bootstrap, Font Awesome, and inline styles/scripts for dropdowns to work
<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src 'self' data: blob:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://cdnjs.cloudflare.com data:; connect-src *;"
</IfModule>

ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php

# Front controller — route everything through public/index.php
RewriteEngine On

# Don't rewrite existing files or directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route to front controller
RewriteRule ^(.*)$ public/index.php [QSA,L]
