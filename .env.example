# OSTA Job Portal Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit the actual .env file.

# Application
APP_ENV=development
SITE_URL=http://localhost/osta%20job%20portal

# Database — Standard
DB_HOST=localhost
DB_PORT=3306
DB_NAME=osta_job_portal
DB_USER=root
DB_PASS=

# Database — Railway MySQL (alternative; automatically detected)
# MYSQL_HOST=your-railway-mysql-host
# MYSQL_PORT=3306
# MYSQL_DATABASE=osta_job_portal
# MYSQL_USER=your-user
# MYSQL_PASSWORD=your-password

# Database — connection string (alternative; Railway provides this)
# DATABASE_URL=mysql://user:pass@host:3306/dbname

# SMTP / Email (for PHPMailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls
FROM_EMAIL=noreply@example.com
FROM_NAME="OSTA Job Portal"
