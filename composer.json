{
    "name": "osta/job-portal",
    "description": "OSTA Job Portal recruitment management system.",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "phpmailer/phpmailer": "^6.8",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "config": {
        "vendor-dir": "vendor",
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "@php scripts/lint.php",
        "test": "@php tests/run_helper_tests.php",
        "smoke": "@php tests/smoke_check.php",
        "phpunit": "vendor/bin/phpunit"
    }
}
