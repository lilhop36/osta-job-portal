{
  "name": "osta-job-portal",
  "private": true,
  "scripts": {
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "newman run tests/postman/osta-api-tests.json --env-var base_url=http://localhost/osta%20job%20portal/api",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:unit": "vendor/bin/phpunit",
    "test:all": "vendor/bin/phpunit && npm run test:api && npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
